# ══════════════════════════════════════════════════
#   ChineseNois — Environment Configuration
#   Copy file này thành .env và điền thông tin thật
# ══════════════════════════════════════════════════

# ── App ───────────────────────────────────────────
APP_NAME=ChineseNois
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Database ──────────────────────────────────────
# SQLite (mặc định, không cần cài thêm)
DATABASE_URL=sqlite:///./chinesenois.db

# PostgreSQL (production — bỏ comment để dùng)
# DATABASE_URL=postgresql://user:password@localhost:5432/chinesenois

# ── JWT Auth ──────────────────────────────────────
SECRET_KEY=chinesenois-super-secret-key-change-this-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 ngày

# ── Admin mặc định (seed data) ────────────────────
ADMIN_EMAIL=admin@chinesenois.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin

# ── PayOS (thanh toán online) ─────────────────────
# Đăng ký tại https://payos.vn
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# ── Google OAuth ──────────────────────────────────
# Đăng ký tại https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Facebook OAuth ────────────────────────────────
# Đăng ký tại https://developers.facebook.com
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/auth/facebook/callback

# ── Email (quên mật khẩu) ─────────────────────────
# Gmail SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password      # App Password (không phải mật khẩu Gmail)
MAIL_FROM=noreply@chinesenois.vn
MAIL_FROM_NAME=ChineseNois

# ── Upload ────────────────────────────────────────
UPLOAD_DIR=static/images
MAX_UPLOAD_SIZE_MB=5

# ── CORS ──────────────────────────────────────────
# Danh sách domain được phép (ngăn cách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Vận chuyển ────────────────────────────────────
SHIPPING_FEE=30000
FREE_SHIPPING_THRESHOLD=500000       # Miễn phí ship khi đơn >= 500k
